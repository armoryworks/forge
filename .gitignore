# --- Sibling repos (each has its own .git, must not be tracked here) ---
/forge-deploy/
/forge-api/
/forge-ui/
/forge-test/
/forge-voice/

# --- Wrapper-local copy (relative paths differ from forge-deploy's) ---
/docker-compose.yml

# --- Junctioned to forge-deploy/tools (Windows directory link) ---
/tools/

# Note: the four overlay compose files (docker-compose.{dev,demo,cohost,
# export}.yml) USED to be gitignored here under a "hard-linked, owned by
# forge-deploy" model. That model meant CI couldn't verify parity (the
# wrapper checkout had no copies to check). Now the four files are
# tracked in BOTH the wrapper and forge-deploy, hard-links keep them in
# sync locally, and .github/workflows/wrapper-invariants.yml verifies
# the wrapper's committed content matches forge-deploy's committed
# content on every PR + push.

# --- Local-only runtime artifacts ---
/.env
/.env.example
/.compose-build.log
/storage/

# --- Local Claude / IDE config ---
/.claude/

# --- Database dumps and local deploy state (huge / machine-specific, never committed) ---
/.db-backups/
/.local-deploy/

# --- Personal scratch (not part of the meta repo) ---
/Future Prompts/
/phase-*-output/
/RESUME-*.md
/Generated Tests/
/node_modules/
