# --- Sibling repos (each has its own .git, must not be tracked here) ---
/forge-deploy/
/forge-api/
/forge-ui/
/forge-test/
/forge-voice/

# --- Wrapper-local copy (relative paths differ from forge-deploy's) ---
/docker-compose.yml

# --- Hard-linked from forge-deploy/ (identical content; edit either side) ---
/docker-compose.dev.yml
/docker-compose.demo.yml
/docker-compose.cohost.yml
/docker-compose.export.yml

# --- Junctioned to forge-deploy/tools (Windows directory link) ---
/tools/

# --- Local-only runtime artifacts ---
/.env
/.env.example
/.compose-build.log
/storage/

# --- Local Claude / IDE config ---
/.claude/

# --- Personal scratch (not part of the meta repo) ---
/Future Prompts/
/phase-*-output/
/RESUME-*.md
/Generated Tests/
/AUDIT.md
/node_modules/
